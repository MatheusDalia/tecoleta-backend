# Exemplo de variáveis de ambiente para PRODUÇÃO
# Copie este arquivo e ajuste os valores conforme sua plataforma

# ===== BANCO DE DADOS =====
# URL completa do banco (Railway, Render, Heroku fornecem isso automaticamente)
DATABASE_URL=postgres://usuario:senha@host:5432/nome_do_banco

# Habilitar SSL para conexão (true para a maioria das plataformas cloud)
DB_SSL=true

# ===== JWT =====
JWT_SECRET=sua_chave_secreta_super_segura_aqui_123456

# ===== EMAIL (para reset de senha) =====
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu-email@gmail.com
EMAIL_PASS=sua-senha-de-app

# ===== SERVIDOR =====
PORT=3000
NODE_ENV=production

# ===== URL BASE (para emails de reset) =====
BASE_URL=https://seu-dominio.com
